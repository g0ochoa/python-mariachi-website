# Django Environment Variables Template
# Copy this file to .env and fill in your actual values
# .env is ignored by Git to keep secrets safe

# Django Settings
SECRET_KEY=your-secret-key-here-generate-a-new-one
DEBUG=True

# Database Configuration (for PostgreSQL - future)
# DB_NAME=mariachi_db
# DB_USER=postgres
# DB_PASSWORD=your-password-here
# DB_HOST=localhost
# DB_PORT=5432

# Email Configuration — enables real contract emails when EMAIL_HOST is set
# (unset = console backend: messages print to the server log instead of sending)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
# DEFAULT_FROM_EMAIL=your-email@gmail.com

# Twilio — enables the automated "Send SMS" button on contracts when all three
# are set (requires a Twilio account + US A2P 10DLC registration)
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_FROM_NUMBER=+14795551234

# Google OAuth (for musician SSO - future)
# GOOGLE_CLIENT_ID=your-client-id
# GOOGLE_CLIENT_SECRET=your-client-secret

# Production Settings
# ALLOWED_HOSTS=mariachitodoterreno.com,www.mariachitodoterreno.com
